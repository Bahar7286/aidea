# Upsert demo users on API startup (Render Postgres). Values: 1|true to force,
# 0|false to disable. Empty = auto-enable when DATABASE_URL is not SQLite.
SEED_DEMO_USERS=1

# Backend
DATABASE_URL=sqlite:///./agritwin.db
# Or Supabase Postgres:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Comma-separated. Production must include the Vercel frontend origin, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://aidea-three.vercel.app
CORS_ORIGINS=http://localhost:3000

# Optional OpenRouter (hybrid AI): rules decide numbers; LLM writes Turkish why/why-not.
# If unset, API falls back to rule-engine explanations only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Frontend (frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional Google Maps (not required — OSM/Leaflet is default)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Supabase client (when using hosted Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
